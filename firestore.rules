rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isMe(uid) { return signedIn() && request.auth.uid == uid; }

    // User data
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if isMe(uid);
    }

    // Friends graph (read-only from client; writes only via Cloud Functions)
    match /friends/{uid}/list/{otherUid} {
      allow read: if isMe(uid);
      allow write: if false;
    }

    // Username registry: usernames/{usernameLower} -> { uid }
    match /usernames/{uname} {
      allow read: if signedIn();

      // create: only owner can create
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;

      // update: only owner, and uid cannot be changed
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;

      // delete: request.resource doesn't exist for deletes, use existing resource
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // Friend invites (write only via Cloud Functions)
    match /friendInvites/{inviteId} {
      allow read, write: if false;
    }

    // Shared challenges
    match /sharedChallenges/{challengeId} {
      // Číst mohou jen členové výzvy
      allow read: if signedIn() && request.auth.uid in resource.data.memberUids;

      // Vytvořit může jen přihlášený uživatel, který je createdBy
      // a zároveň je členem výzvy; povoleno 2 až 10 členů
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberUids is list
        && request.resource.data.memberUids.size() >= 2
        && request.resource.data.memberUids.size() <= 10
        && request.auth.uid in request.resource.data.memberUids;

      // 🔥 JEDINÁ ZMĚNA – zjednodušený update (aby fungovalo odejít)
     allow update: if signedIn()
        && (
          request.auth.uid in resource.data.memberUids
          || (
            resource.data.leftBy is list
            && request.auth.uid in resource.data.leftBy
          )
        )
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.memberUids is list
        && request.resource.data.acceptedBy is list;

      // Progress pro konkrétní dny
      match /progress/{dateISO} {
        allow read: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/sharedChallenges/$(challengeId)).data.memberUids;

        allow create, update: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/sharedChallenges/$(challengeId)).data.memberUids
          && request.resource.data.date == dateISO
          && request.resource.data.users is map
          && request.resource.data.users[request.auth.uid] is map;

        allow delete: if false;
      }

      // Mazání z klienta necháme zakázané
      allow delete: if false;
    }

    // Legacy invites (nepoužívat; ponecháno kvůli zpětné kompatibilitě)
    match /invites/{token} {
      allow read, write: if false;
    }
  }
}