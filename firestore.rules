rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isMe(uid) { return signedIn() && request.auth.uid == uid; }

    // User data
    match /users/{uid} {
  allow read: if signedIn();
  allow write: if isMe(uid);
}

    // Friends graph (read-only from client; writes only via Cloud Functions)
    match /friends/{uid}/list/{otherUid} {
      allow read: if isMe(uid);
      allow write: if false;
    }

    // Username registry: usernames/{usernameLower} -> { uid }
    match /usernames/{uname} {
      allow read: if signedIn();
      // create: only owner can create
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;

      // update: only owner, and uid cannot be changed
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;

      // delete: request.resource doesn't exist for deletes, use existing resource
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // Friend invites (write only via Cloud Functions)
    match /friendInvites/{inviteId} {
      allow read, write: if false;
    }

    // Shared challenges
    match /sharedChallenges/{challengeId} {
      // Číst mohou jen členové výzvy
      allow read: if signedIn() && request.auth.uid in resource.data.memberUids;

      // Vytvořit může jen přihlášený uživatel, který je createdBy
      // a zároveň je jedním ze dvou členů výzvy
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberUids is list
        && request.resource.data.memberUids.size() == 2
        && request.auth.uid in request.resource.data.memberUids;

      // Update může udělat jen člen výzvy
      allow update: if signedIn()
        && request.auth.uid in resource.data.memberUids
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.memberUids == resource.data.memberUids;

      // Mazání z klienta radši zakázat
      allow delete: if false;
    }

    // Shared challenge progress
    match /sharedChallenges/{challengeId}/progress/{dateISO} {
      // Číst mohou jen členové výzvy
      allow read: if signedIn()
        && request.auth.uid in
          get(/databases/$(database)/documents/sharedChallenges/$(challengeId)).data.memberUids;

      // Zapisovat může jen člen výzvy
      allow create, update: if signedIn()
        && request.auth.uid in
          get(/databases/$(database)/documents/sharedChallenges/$(challengeId)).data.memberUids;

      allow delete: if false;
    }
    // Legacy invites (nepoužívat; ponecháno kvůli zpětné kompatibilitě)
    match /invites/{token} {
      allow read, write: if false;
    }
  }
}
