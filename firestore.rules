rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isMe(uid) { return signedIn() && request.auth.uid == uid; }

    // User data
    match /users/{uid} {
  allow read: if signedIn();
  allow write: if isMe(uid);
}

    // Friends graph (read-only from client; writes only via Cloud Functions)
    match /friends/{uid}/list/{otherUid} {
      allow read: if isMe(uid);
      allow write: if false;
    }

    // Username registry: usernames/{usernameLower} -> { uid }
    match /usernames/{uname} {
      allow read: if signedIn();
      // create: only owner can create
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;

      // update: only owner, and uid cannot be changed
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;

      // delete: request.resource doesn't exist for deletes, use existing resource
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // Friend invites (write only via Cloud Functions)
    match /friendInvites/{inviteId} {
      allow read, write: if false;
    }

    // Legacy invites (nepoužívat; ponecháno kvůli zpětné kompatibilitě)
    match /invites/{token} {
      allow read, write: if false;
    }
  }
}
